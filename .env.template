# Site URL (used in build metadata and sitemap)
SITE=http://localhost

# Base path for GitHub Pages deployment (leave empty for root or local dev)
# For GitHub Pages: BASE_PATH=/your-repo-name/
BASE_PATH=

# GitHub repo for Sveltia CMS backend (format: org/repo or user/repo)
REPO=YOUR_ORG/YOUR_REPO

# Sveltia CMS auth proxy URL (leave empty if not using GitHub auth)
AUTH_BASE_URL=

# Branch for Sveltia CMS (defaults to 'main')
BRANCH=main
